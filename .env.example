# Application
PORT=3030
# Comma-separated list of origins allowed by CORS (the Next.js frontend).
CORS_ORIGIN=http://localhost:3000

# PostgreSQL — must match docker-compose.yml
DB_HOST=localhost
# Host port 5433 to avoid clashing with a local Postgres on 5432.
DB_PORT=5433
DB_USERNAME=malta
DB_PASSWORD=malta
DB_DATABASE=malta_lms

# TypeORM: auto-create schema from entities (fine for dev, disable in prod).
DB_SYNCHRONIZE=true
# Re-seed reference/demo data on boot when the tables are empty.
DB_SEED=true
